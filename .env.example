# Copy this file to ".env" and fill in your keys.
# Expo automatically loads EXPO_PUBLIC_* variables into the client bundle.

# OpenAI (gpt-4o) — used for all AI features.
# For production, proxy these calls through your own backend instead of shipping the key.
EXPO_PUBLIC_OPENAI_API_KEY=

# Your backend base URL that creates Stripe Checkout sessions.
# Leave empty to run subscriptions in demo mode.
EXPO_PUBLIC_API_URL=
