# Copy this file to ".env" and fill in your keys.
# Expo automatically loads EXPO_PUBLIC_* variables into the client bundle.

# PrefAI backend base URL (auth, journeys, documents, AI proxy).
# Leave empty to default to http://localhost:3001 in development.
EXPO_PUBLIC_API_URL=

# Optional: enables Journey Step AI chat (client-side). Prefer moving this to the
# backend later; do not commit real keys.
EXPO_PUBLIC_OPENAI_API_KEY=
